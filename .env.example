# Copy this file to .env.local and fill only the values you need.
# Never commit .env.local or any real credential file.

# Local cluster and port-forward settings.
CLUSTER_NAME=devops-lite
LOCAL_PORT=5035
FALLBACK_LOCAL_PORT=5037
IMAGE_NAME=weather-live-stream:local

# Argo CD bootstrap.
# Example: https://github.com/kimwoct/devops.git
REPO_URL=
ARGOCD_NAMESPACE=argocd
ARGOCD_VERSION=v2.13.3

# ngrok public demo.
# Paste the token only in .env.local, not in markdown, chat, or shell history.
NGROK_AUTHTOKEN=
NGROK_LOCAL_URL=http://127.0.0.1:5035
NGROK_URL=
NGROK_BASIC_AUTH_ENABLED=false
NGROK_BASIC_AUTH_USER=demo
NGROK_BASIC_AUTH_PASSWORD=

# Weather app runtime configuration.
# These are non-secret local defaults, but keeping them here makes local overrides explicit.
OTEL_SERVICE_NAME=weather-live-stream
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector.observability.svc.cluster.local:4317
WEATHER_REDIS_CONNECTION_STRING=redis-master.data.svc.cluster.local:6379
WEATHER_KAFKA_BOOTSTRAP_SERVERS=redpanda.streaming.svc.cluster.local:9093
WEATHER_TOPIC=weather.observations
